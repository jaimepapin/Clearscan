# ─── Copy this file to .env.local for local dev ───────────────────────────
# NEVER commit .env.local to git — it is in .gitignore

# Required — your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the default model
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct

# Optional — Supabase (for persistent bill history across devices)
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
